{% extends "base.html.j2" %}
{% block content %}
<div class="hero">
  <div>
    <div class="eyebrow">Leadership Readout</div>
    <h2>Executive Surface</h2>
    <p>Track cleanup progress, approval motion and campaign health without dropping into raw artifacts unless something really needs investigation.</p>
  </div>
</div>

<div class="cards">
  <div class="card"><strong>{{ executive.latest_run.run_id if executive.latest_run else 'n/a' }}</strong><span>Latest indexed run</span></div>
  <div class="card"><strong>{{ executive.latest_run.policy_health.overall.score if executive.latest_run and executive.latest_run.policy_health and executive.latest_run.policy_health.overall else 'n/a' }}</strong><span>Health score</span></div>
  <div class="card"><strong>{{ executive.overdue_count }}</strong><span>Overdue items</span></div>
  <div class="card"><strong>{{ executive.campaign_summary | length }}</strong><span>Tracked campaigns</span></div>
  <div class="card"><strong>{{ executive.approval_counts.approved if executive.approval_counts.approved is defined else 0 }}</strong><span>Approved items</span></div>
  <div class="card"><strong>{{ executive.activity | length }}</strong><span>Recent activity events</span></div>
</div>

{% if executive.latest_run %}
<section class="panel spotlight">
  <h3>Executive Readout</h3>
  <div class="summary-strip">
    <span class="summary-pill"><strong>Latest run:</strong> {{ executive.latest_run.run_id }}</span>
    <span class="summary-pill"><strong>Queue size:</strong> {{ executive.latest_run.summary.review_queue_count or 0 }}</span>
    <span class="summary-pill"><strong>Findings:</strong> {{ executive.latest_run.summary.findings_count or 0 }}</span>
  </div>
  <p class="small muted">Use this page to answer three questions quickly: is cleanup debt shrinking, are approvals moving, and which campaigns or owners need escalation.</p>
</section>
{% endif %}

<div class="grid-2">
  <section class="panel">
    <h3>Action Mix</h3>
    <p class="table-intro">This is the operational shape of the backlog: what we can remove, what needs narrowing, and what needs structural cleanup.</p>
    {% if executive.queue_action_counts %}
    <ul class="kpi-list">
      {% for action, count in executive.queue_action_counts.items() %}
      <li class="kpi-row"><span><span class="badge {{ action }}">{{ action }}</span></span><strong>{{ count }}</strong></li>
      {% endfor %}
    </ul>
    {% else %}
    <div class="empty-state">
      <strong>No queue action data yet.</strong>
      <div class="small muted">Import a run with queue artifacts to populate this summary.</div>
    </div>
    {% endif %}
  </section>
  <section class="panel">
    <h3>Approval Mix</h3>
    <p class="table-intro">This is the workflow heartbeat: how much is still pending, what has already cleared, and what is blocked or rejected.</p>
    {% if executive.approval_counts %}
    <ul class="kpi-list">
      {% for approval, count in executive.approval_counts.items() %}
      <li class="kpi-row"><span><span class="badge {{ approval }}">{{ approval }}</span></span><strong>{{ count }}</strong></li>
      {% endfor %}
    </ul>
    {% else %}
    <div class="empty-state">
      <strong>No approval workflow data yet.</strong>
      <div class="small muted">Approval activity will surface here once reviewers start moving shared queue items.</div>
    </div>
    {% endif %}
  </section>
</div>

<div class="grid-2">
  <section class="panel">
    <h3>Campaign Health</h3>
    <p class="table-intro">Campaigns should read like delivery lanes: owner, team reach, open volume and whether they are still actively moving.</p>
    {% if executive.campaign_summary %}
    <div class="list-table">
      {% for campaign in executive.campaign_summary %}
      {% set completion = 0 if not campaign.queue_count else (((campaign.queue_count - campaign.open_count) / campaign.queue_count) * 100) | round(0, 'floor') %}
      <div class="list-row">
        <div>
          <div class="list-row-title">{{ campaign.name }}</div>
          <div class="list-row-meta">Owner {{ campaign.owner }} · {{ campaign.member_count }} members · <span class="badge {{ 'ok' if campaign.status == 'active' else 'warn' }}">{{ campaign.status }}</span></div>
          <div style="margin-top:12px;" class="progress"><div class="progress-bar" style="width: {{ completion }}%;"></div></div>
          <div class="progress-meta"><span>{{ campaign.open_count }}/{{ campaign.queue_count }} open</span><strong>{{ completion }}%</strong></div>
        </div>
        <div class="list-row-side">
          <a href="/queue?campaign={{ campaign.campaign_key }}"><button type="button" class="secondary">Open queue</button></a>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-state">
      <strong>No campaign data yet.</strong>
      <div class="small muted">Create a campaign to start tracking team-oriented cleanup progress.</div>
    </div>
    {% endif %}
  </section>
  <section class="panel">
    <h3>Owner Workload</h3>
    <p class="table-intro">This tells us where queue weight is accumulating and who is carrying approved items versus still-open backlog.</p>
    {% if executive.owner_summary %}
    <div class="table-wrap">
      <table>
        <thead><tr><th>Owner</th><th>Total</th><th>Open</th><th>Approved</th></tr></thead>
        <tbody>
          {% for owner, summary in executive.owner_summary.items() %}
          <tr><td>{{ owner }}</td><td>{{ summary.total }}</td><td>{{ summary.open }}</td><td>{{ summary.approved }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div class="empty-state">
      <strong>No owner workload yet.</strong>
      <div class="small muted">Assigning items and campaigns will populate this view.</div>
    </div>
    {% endif %}
  </section>
</div>

<div class="grid-2">
  <section class="panel">
    <h3>Recent Workflow Activity</h3>
    <p class="table-intro">Use this as the motion log for the last shared changes across assignment, approval and analyst collaboration.</p>
    {% if executive.activity %}
    <div class="table-wrap">
      <table>
        <thead><tr><th>When</th><th>Type</th><th>User</th><th>Rule</th><th>Notes</th></tr></thead>
        <tbody>
          {% for item in executive.activity %}
          <tr>
            <td>{{ item.changed_at }}</td>
            <td><span class="badge {{ 'ok' if item.activity_type in ['approval_update','assignment_update'] else 'warn' }}">{{ item.activity_type }}</span></td>
            <td>{{ item.changed_by }}</td>
            <td>{{ item.rule_uid }}</td>
            <td>{{ item.notes[:90] }}{% if item.notes|length > 90 %}...{% endif %}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div class="empty-state">
      <strong>No audit activity yet.</strong>
      <div class="small muted">Commenting, assignment and approval updates will appear here.</div>
    </div>
    {% endif %}
  </section>
  <section class="panel">
    <h3>Audit Highlights</h3>
    <p class="table-intro">A compact count of what kind of activity is actually happening in the shared workflow right now.</p>
    {% if executive.audit_highlights %}
    <ul class="kpi-list">
      {% for event_type, count in executive.audit_highlights.items() %}
      <li class="kpi-row"><span>{{ event_type }}</span><strong>{{ count }}</strong></li>
      {% endfor %}
    </ul>
    {% else %}
    <div class="empty-state">
      <strong>No audit highlights yet.</strong>
      <div class="small muted">The latest run has not accumulated enough workflow activity to summarize.</div>
    </div>
    {% endif %}
  </section>
</div>

<section class="panel">
  <h3>Trend</h3>
  <p class="table-intro">A light historical view of backlog size, findings count and health score across indexed runs.</p>
  {% if executive.trend %}
  <div class="table-wrap">
    <table>
      <thead><tr><th>Run</th><th>Generated</th><th>Queue</th><th>Findings</th><th>Health</th></tr></thead>
      <tbody>
        {% for point in executive.trend %}
        <tr>
          <td>{{ point.run_id }}</td>
          <td>{{ point.generated_at }}</td>
          <td>{{ point.queue_count }}</td>
          <td>{{ point.findings_count }}</td>
          <td>{{ point.health_score or 'n/a' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty-state">
    <strong>No run history yet.</strong>
    <div class="small muted">Trend data appears after the first indexed runs are available.</div>
  </div>
  {% endif %}
</section>
{% endblock %}
