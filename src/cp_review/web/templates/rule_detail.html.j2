{% extends "base.html.j2" %}
{% block content %}
<div class="hero"><div><h2>Rule Detail</h2><p>Explainability, semantic relationships and remediation rationale.</p></div><div><a href="/simulate/{{ payload.rule.rule_uid }}?run_id={{ run_id }}">Open simulation</a></div></div>
<div class="cards">
  <div class="card"><strong>{{ payload.summary.finding_count }}</strong><span>Findings</span></div>
  <div class="card"><strong>{{ payload.summary.queue_item_count }}</strong><span>Queue Items</span></div>
  <div class="card"><strong>{{ payload.related_rules | length }}</strong><span>Related Rules</span></div>
</div>
<div class="grid-2">
  <section class="panel">
    <h3>{{ payload.rule.rule_name or payload.rule.rule_uid }}</h3>
    <p><strong>Package:</strong> {{ payload.rule.package_name }}<br><strong>Layer:</strong> {{ payload.rule.layer_name }}<br><strong>Rule number:</strong> {{ payload.rule.rule_number }}</p>
    <p><strong>Action:</strong> {{ payload.rule.action }} · <strong>Track:</strong> {{ payload.rule.track }}</p>
    <p class="muted">Related rules: {{ payload.related_rules | join(', ') if payload.related_rules else 'none' }}</p>
  </section>
  <section class="panel">
    <h3>Queue Workflow</h3>
    <table><thead><tr><th>Action</th><th>Priority</th><th>Approval</th><th>Next Step</th></tr></thead><tbody>{% for item in payload.queue_items %}<tr><td><span class="badge {{ item.action_type }}">{{ item.action_type }}</span></td><td>{{ item.priority }}</td><td>{{ item.approval_status }}</td><td>{{ item.suggested_next_step }}</td></tr>{% else %}<tr><td colspan="4">No queue items.</td></tr>{% endfor %}</tbody></table>
    {% if payload.queue_items %}
    <div class="inline-form" style="margin-top:14px;">
      <select id="detail-status">{% for option in ['new','accepted','false_positive','needs_owner_input','deferred','done'] %}<option value="{{ option }}">{{ option }}</option>{% endfor %}</select>
      <select id="detail-approval">{% for option in ['pending','approved','rejected'] %}<option value="{{ option }}">{{ option }}</option>{% endfor %}</select>
      <input id="detail-owner" placeholder="owner">
      <input id="detail-campaign" placeholder="campaign">
      <button type="button" onclick="updateRuleState()">Update Rule Workflow</button>
    </div>
    {% endif %}
  </section>
</div>
<section class="panel">
  <h3>Comments</h3>
  {% if current_user.role in ['reviewer','approver','admin'] %}
  <div class="inline-form" style="margin-bottom:14px;">
    <input id="detail-comment" placeholder="add comment for this rule" style="min-width:320px;">
    <button type="button" class="secondary" onclick="addComment()">Add Comment</button>
  </div>
  {% endif %}
  <table>
    <thead><tr><th>Author</th><th>Created</th><th>Comment</th></tr></thead>
    <tbody>
      {% for comment in comments %}
      <tr><td>{{ comment.author }}</td><td>{{ comment.created_at }}</td><td>{{ comment.comment }}</td></tr>
      {% else %}
      <tr><td colspan="3">No comments yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</section>
<section class="panel">
  <h3>Findings Payload</h3>
  <pre>{{ payload.findings | tojson(indent=2) }}</pre>
</section>
<script>
async function updateRuleState() {
  await fetch('/api/review-state', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      rule_uid: '{{ payload.rule.rule_uid }}',
      status: document.getElementById('detail-status').value,
      approval_status: document.getElementById('detail-approval').value,
      owner: document.getElementById('detail-owner').value,
      campaign: document.getElementById('detail-campaign').value,
    }),
  });
  window.location.reload();
}
async function addComment() {
  const itemId = '{{ payload.queue_items[0].item_id if payload.queue_items else "" }}';
  const comment = document.getElementById('detail-comment').value;
  if (!itemId || !comment) {
    window.alert('Provide a comment first.');
    return;
  }
  await fetch('/api/comments', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ item_id: itemId, comment }),
  });
  window.location.reload();
}
</script>
{% endblock %}
